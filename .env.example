# Optional: Statbank API base URL (client-visible — use only your own same-origin proxy in production).
# Default in dev/preview: /api/statbank/v1 (proxied by Vite to https://api.statbank.dk)
# VITE_DST_API_BASE=/api/statbank/v1

# Public site URL for canonical links, Open Graph, sitemap, and robots.txt (no trailing slash).
# Vercel sets VERCEL_URL automatically at build time; override with your custom domain:
# VITE_SITE_URL=https://your-domain.example
